# Copy to `.env` in the project root and edit there (`.env` is gitignored). Restart uvicorn after changes.

# Public URL used inside QR payloads for short links (production HTTPS origin)
PUBLIC_BASE_URL=https://your-domain.example

# Protect /api/admin/* and the admin UI token field — pick a long random string
ADMIN_SECRET=

# Optional: HTTP port — ./run.sh dev binds uvicorn here (default 8000). Docker Compose maps host ${PORT} -> container 8000.
# PORT=8000

# Optional: override GitHub URL for header + footer icon (defaults to Benedict-CS/QRender if unset)
# PUBLIC_GITHUB_URL=https://github.com/you/QRender
